{
  "name": "nimbalyst-monorepo",
  "version": "0.33.1",
  "private": true,
  "description": "Monorepo for Nimbalyst - A rich text editor built with Meta's Lexical framework",
  "author": "Nimbalyst Team",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nimbalyst/nimbalyst.git"
  },
  "scripts": {
    "build": "npm run build --prefix packages/runtime",
    "typecheck": "npm run typecheck -ws --if-present",
    "typecheck:prepush": "npm run build --workspace=@nimbalyst/extension-sdk && npm run build --workspace=@nimbalyst/runtime && npm run build --prefix packages/extensions/nimbalyst-memory/engine && npm run typecheck",
    "test": "npm run test:unit",
    "test:unit": "vitest",
    "test:prepush": "vitest --run",
    "test:prepush-gate": "node --test scripts/__tests__/prepush-test-gate.test.mjs scripts/__tests__/check-main-bundle-graph.test.mjs scripts/__tests__/check-push-authors.test.mjs",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest --coverage",
    "test:provider:integration": "cross-env RUN_AI_PROVIDER_TESTS=true vitest --run",
    "prepare": "node scripts/install-git-hooks.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "check:override-sync": "node scripts/check-override-sync.mjs",
    "check:bundle-graph": "node scripts/check-main-bundle-graph.mjs",
    "extension-sdk:check-public": "bash scripts/extension-sdk-public-checks.sh",
    "analyze": "node scripts/bundle-size.js",
    "analyze:top": "node scripts/bundle-size.js --top",
    "clean": "rm -rf packages/*/node_modules/.vite packages/*/dist node_modules/.cache",
    "clean:full": "rm -rf packages/*/node_modules packages/*/dist node_modules && npm install",
    "ios:test:swift": "npm run test:swift --prefix packages/ios",
    "ios:build:transcript": "npm run build:transcript --prefix packages/ios",
    "ios:build:editor": "npm run build:editor --prefix packages/ios",
    "android:build:transcript": "npm run build:transcript --prefix packages/android",
    "android:test:unit": "npm run android:test:unit --prefix packages/android",
    "android:assemble:debug": "npm run android:assemble:debug --prefix packages/android",
    "android:assemble:release": "npm run android:assemble:release --prefix packages/android",
    "android:bundle:release": "npm run android:bundle:release --prefix packages/android",
    "android:bundle:signed": "./scripts/android-bundle-signed.sh",
    "test:extensions": "bash scripts/run-extension-tests.sh",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@babel/plugin-transform-flow-strip-types": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@electric-sql/pglite-tools": "0.2.19",
    "@lexical/clipboard": "^0.44.0",
    "@lexical/code": "^0.44.0",
    "@lexical/code-shiki": "^0.44.0",
    "@lexical/dragon": "^0.44.0",
    "@lexical/file": "^0.44.0",
    "@lexical/hashtag": "^0.44.0",
    "@lexical/headless": "^0.44.0",
    "@lexical/history": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/mark": "^0.44.0",
    "@lexical/markdown": "^0.44.0",
    "@lexical/overflow": "^0.44.0",
    "@lexical/plain-text": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/table": "^0.44.0",
    "@lexical/text": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "@lexical/yjs": "^0.44.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.17.1",
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.0.12",
    "lexical": "^0.44.0",
    "patch-package": "8.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "terser": "^5.31.0",
    "typescript": "^5.0.0",
    "vitest": "4.1.8"
  },
  "workspaces": [
    "packages/electron",
    "packages/runtime",
    "packages/cli",
    "packages/core",
    "packages/collab-protocol",
    "packages/collab-adapters",
    "packages/ios",
    "packages/android",
    "packages/extension-sdk",
    "packages/extensions/*",
    "packages/marketplace"
  ],
  "dependencies": {
    "@types/node-forge": "^1.3.14",
    "ajv-formats": "^3.0.1",
    "content-type": "^1.0.5",
    "cors": "^2.8.5",
    "cross-spawn": "^7.0.6",
    "es-module-shims": "^2.7.0",
    "esbuild": "^0.27.4",
    "eventsource": "^4.1.0",
    "eventsource-parser": "^3.0.6",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "monaco-editor": "^0.55.1",
    "node-forge": "^1.3.2",
    "node-pty": "^1.1.0",
    "openai": "^6.9.1",
    "pkce-challenge": "^5.0.0",
    "raw-body": "^3.0.1",
    "virtua": "^0.48.2",
    "zod-to-json-schema": "^3.25.0"
  },
  "overrides": {
    "@anthropic-ai/claude-agent-sdk": "0.3.217",
    "prismjs": "^1.30.0",
    "vite": "^7.0.0",
    "zod": "^4.0.0",
    "concurrently": {
      "shell-quote": "^1.8.4"
    },
    "minimatch@^10.0.0": "^10.2.5"
  },
  "allowScripts": {
    "@fortawesome/fontawesome-free@5.15.4": true,
    "@vscode/ripgrep@1.17.1": true,
    "better-sqlite3@13.0.1": true,
    "bufferutil@4.1.0": true,
    "core-js@3.48.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.27.7": true,
    "esbuild@0.27.3": true,
    "esbuild@0.25.10": true,
    "electron-winstaller@5.4.0": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true,
    "leveldown@5.6.0": true,
    "node-pty@1.1.0": true,
    "playwright-electron@0.5.0": true,
    "sharp@0.34.5": true,
    "utf-8-validate@5.0.10": true,
    "workerd@1.20260421.1": true
  }
}
