plans/

# Stray patch files (working snapshots, never source)
*.patch

# MCP config (may contain personal API tokens)
.mcp.json

# Database recovery dumps (one-off triage artifacts, never publish)
recovered-data/
recovered-data-recent/

# iOS build artifacts
*.ipa

# E2E test output (screenshots, videos, etc.)
e2e_test_output/
e2e-screenshots/
test-results/
.superloop/

# Generated marketing assets
packages/electron/marketing/output/
packages/electron/marketing/screenshots/
packages/electron/marketing/videos/

# Test screenshots
packages/electron/e2e/permissions/screenshots/
packages/electron/e2e/smoke/screenshots/
packages/electron/e2e/walkthroughs/screenshots/
packages/ios/screenshots/

# Auto-generated platform artifacts
packages/android/app/schemas/
packages/marketplace/.wrangler/

# Scratch/working directories at repo root (not source)
/marketing/
/e2e/
/tests/
/test-offscreen-editors/

# Firebase config (commit only after auditing Security Rules)
packages/android/app/google-services.json

# Android signing keystores — never commit. Secrets come from 1Password via op run.
*.jks
*.keystore
nimbalyst-android-upload.jks
# op-run env template with resolved secrets (the op:// template itself is safe to commit)
.env.android-signing.local

# Generated bundle / packaged extension artifact
packages/electron/index.js
packages/browser-extension/nimbalyst-web-clipper.zip
# Built-in extensions ship via build:extensions + electron-builder, not as committed .nimext blobs
packages/electron/resources/bundled-extensions/*.nimext

# accidentally-tracked SQLite caches
packages/electron/data/*.db
packages/electron/memories.db

# Local RAG/memory-tool artifacts (SQLite stores + caches created in the cwd)
memories.db
.rag-cache/
