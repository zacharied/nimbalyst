<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".NimbalystApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NimbalystAndroid">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.NimbalystAndroid.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="auth"
                    android:pathPrefix="/callback"
                    android:scheme="nimbalyst" />
            </intent-filter>
            <!-- Pairing payloads are accepted only by the in-app QR scanner.
                 MainActivity must not expose them as external deep links because
                 they select the sync server and encryption context. -->
            <!-- Note: nimbalyst://session/[id] is delivered only via the push
                 notification's explicit Intent(MainActivity) (see
                 NimbalystFirebaseMessagingService). No BROWSABLE intent-filter is
                 declared for it, which would needlessly let any web page invoke it. -->
        </activity>

        <service
            android:name=".notifications.NimbalystFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
