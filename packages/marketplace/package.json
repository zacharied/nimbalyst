{
  "name": "@nimbalyst/marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "XDG_CONFIG_HOME=\"$HOME/.config/nimbalyst\" wrangler dev --local --ip 0.0.0.0",
    "deploy": "XDG_CONFIG_HOME=\"$HOME/.config/nimbalyst\" wrangler deploy",
    "deploy:production": "XDG_CONFIG_HOME=\"$HOME/.config/nimbalyst\" ./scripts/deploy.sh patch --env production",
    "deploy:staging": "XDG_CONFIG_HOME=\"$HOME/.config/nimbalyst\" ./scripts/deploy.sh patch --env staging",
    "publish-extensions": "XDG_CONFIG_HOME=\"$HOME/.config/nimbalyst\" ./scripts/publish-extensions.sh",
    "login": "XDG_CONFIG_HOME=\"$HOME/.config/nimbalyst\" wrangler login",
    "logout": "XDG_CONFIG_HOME=\"$HOME/.config/nimbalyst\" wrangler logout",
    "whoami": "XDG_CONFIG_HOME=\"$HOME/.config/nimbalyst\" wrangler whoami",
    "wrangler": "XDG_CONFIG_HOME=\"$HOME/.config/nimbalyst\" wrangler",
    "types": "XDG_CONFIG_HOME=\"$HOME/.config/nimbalyst\" wrangler types"
  },
  "devDependencies": {
    "wrangler": "^4.14.4",
    "typescript": "^5.7.3"
  }
}
