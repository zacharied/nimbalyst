{
  "name": "@nimbalyst/extension-sdk",
  "version": "0.2.2",
  "description": "SDK for building Nimbalyst extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/nimbalyst/nimbalyst.git",
    "directory": "packages/extension-sdk"
  },
  "homepage": "https://docs.nimbalyst.com/extensions",
  "bugs": {
    "url": "https://github.com/nimbalyst/nimbalyst/issues"
  },
  "type": "module",
  "sideEffects": false,
  "browser": {
    "./dist/validate.js": "./dist/validate.browser.js"
  },
  "nimbalyst": {
    "minAppVersion": "0.58.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./file-tree": {
      "types": "./dist/fileDirectoryTree.d.ts",
      "import": "./dist/fileDirectoryTree.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "vite": "^7.1.12",
    "@vitejs/plugin-react": "^5.1.2",
    "tailwindcss": "^3.4.0",
    "yjs": ">=13.5.42",
    "y-protocols": "^1.0.5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    },
    "yjs": {
      "optional": true
    },
    "y-protocols": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.0.0",
    "vite": "^7.1.12",
    "@vitejs/plugin-react": "^5.1.2",
    "yjs": ">=13.5.42",
    "y-protocols": "^1.0.5"
  },
  "keywords": [
    "nimbalyst",
    "extension",
    "sdk",
    "plugin",
    "custom-editor",
    "ai-tools"
  ],
  "license": "MIT"
}
